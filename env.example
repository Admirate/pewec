# =============================================================================
# Supabase
# Run `supabase status` after `supabase start` to get local dev values.
# =============================================================================

# Public (exposed to the browser)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# Email (SMTP via nodemailer)
# Local dev: Mailpit is bundled with `supabase start`.
#   Web UI: http://127.0.0.1:54324
#   SMTP:   127.0.0.1:54325 (no auth required)
#
# Production: point to any SMTP provider (e.g. Resend, Postmark, SES).
# =============================================================================

EMAIL_SMTP_HOST=127.0.0.1
EMAIL_SMTP_PORT=54325
EMAIL_SMTP_SECURE=false
# EMAIL_SMTP_USER=          # uncomment and set for authenticated SMTP
# EMAIL_SMTP_PASS=          # uncomment and set for authenticated SMTP

# The "From" address used for all outgoing emails.
# Defaults to noreply@pewec-pptt.org if unset.
EMAIL_FROM=noreply@pewec-pptt.org

NEXT_PUBLIC_CANONICAL_URL="http://localhost:3000/"
